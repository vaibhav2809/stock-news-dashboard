# === Database ===
POSTGRES_DB=stocknews
POSTGRES_USER=stocknews
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6379

# === JWT ===
JWT_SECRET=CHANGE_ME_at_least_32_chars_random_string

# === API Keys ===
FINNHUB_API_KEY=your_finnhub_api_key
NEWSDATA_API_KEY=your_newsdata_io_api_key

# === Rate Limiting ===
RATE_LIMIT_DAILY_PER_USER=100
RATE_LIMIT_DAILY_ANONYMOUS=30

# === Spring Boot ===
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# === App Port (host-side port for production docker-compose) ===
APP_PORT=80
